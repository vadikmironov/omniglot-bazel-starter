# After editing this file, regenerate the lockfile:
#   bazel run //tools/python:generate_requirements_lock.update

###############################################################################
# development dependencies
###############################################################################

# --- BEGIN feature:lint ---
# linter & formatter CLI for local runs / editor integration. Bazel formatting
# uses the rules_lint ruff binary, so this is only needed for the lint feature.
ruff
# security linter
bandit
# type checker
ty
# --- END feature:lint ---
# git pre-commit hooks framework
pre-commit

# --- BEGIN feature:profiling ---
# CPU bench framework driven by bazel run //tools/profile
pytest
pytest-benchmark
# in-process CPU sampler; the bench conftest renders its session as folded stacks
pyinstrument
# heap capture for the one-shot memory workloads (Linux/macOS only)
memray
# --- END feature:profiling ---

# --- BEGIN user-managed ---
# Your project's pip dependencies. Preserved across re-bootstrap.
# --- END user-managed ---

# --- BEGIN exclude ---
###############################################################################
# bootstrap tool dependency
###############################################################################

questionary

###############################################################################
# example dependency for python_app_with_ext_dep
###############################################################################

requests
# --- END exclude ---