#!/usr/bin/env bash
#
# Bazel credential helper that reads authentication from ~/.netrc
#
# This script implements the Bazel credential helper protocol:
# https://github.com/bazelbuild/proposals/blob/main/designs/2022-06-07-bazel-credential-helpers.md
#
# It reads a JSON request from stdin with a "uri" field, extracts the hostname,
# looks up credentials in ~/.netrc, and returns HTTP headers as JSON on stdout.
#
# IMPORTANT: This script must remain a plain shell script (not Bazel-built)
# to avoid a bootstrap chicken-and-egg problem — Bazel needs credentials
# before it can build anything.
#
set -euo pipefail

# Source the shared .netrc parsing library (provides netrc_lookup).
source "$(dirname "${BASH_SOURCE[0]}")/netrc_lib.sh"

# Read the request JSON from stdin
request=$(cat)

# Extract the URI from the request
uri=$(echo "${request}" | grep -o '"uri" *: *"[^"]*"' | head -1 | sed 's/.*: *"//;s/"$//' || true)

if [ -z "${uri}" ]; then
    echo '{"headers":{}}'
    exit 0
fi

# Extract hostname from URI
host=$(echo "${uri}" | sed -E 's|^https?://||' | cut -d'/' -f1 | cut -d':' -f1)

netrc_lookup "${host}"

if [ -z "${NETRC_LOGIN}" ] || [ -z "${NETRC_PASSWORD}" ]; then
    echo '{"headers":{}}'
    exit 0
fi

# Return Basic auth header in credential helper JSON format
encoded=$(echo -n "${NETRC_LOGIN}:${NETRC_PASSWORD}" | base64 -w0 2>/dev/null || echo -n "${NETRC_LOGIN}:${NETRC_PASSWORD}" | base64)
echo "{\"headers\":{\"Authorization\":[\"Basic ${encoded}\"]}}"
