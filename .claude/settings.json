{
    "model": "opus",
    "statusLine": {
        "type": "command",
        "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); version=$(echo \"$input\" | jq -r '.version'); cwd=$(echo \"$input\" | jq -r '.cwd'); usage=$(echo \"$input\" | jq '.context_window.current_usage'); if [ \"$usage\" != \"null\" ]; then current=$(echo \"$usage\" | jq '.input_tokens + .cache_creation_input_tokens + .cache_read_input_tokens'); size=$(echo \"$input\" | jq '.context_window.context_window_size'); pct=$((current * 100 / size)); ctx=\"${pct}%\"; else ctx=\"0%\"; fi; branch=\"\"; if git -C \"$cwd\" rev-parse --git-dir >/dev/null 2>&1; then branch=$(git -C \"$cwd\" --no-optional-locks rev-parse --abbrev-ref HEAD 2>/dev/null); [ -n \"$branch\" ] && branch=\" ($branch)\"; fi; printf \"\\033[01;32m%s@%s\\033[00m:\\033[01;34m%s\\033[00m\\033[01;36m%s\\033[00m | \\033[01;33m%s\\033[00m | v%s | ctx: \\033[01;35m%s\\033[00m\" \"$(whoami)\" \"$(hostname -s)\" \"$cwd\" \"$branch\" \"$model\" \"$version\" \"$ctx\""
    },
    "permissions": {
        "allow": [
            "WebFetch(domain:github.com)",
            "WebFetch(domain:*.github.com)",
            "WebFetch(domain:raw.githubusercontent.com)",
            "WebFetch(domain:bazel.build)",
            "WebFetch(domain:docs.bazel.build)",
            "WebFetch(domain:bazelbuild.github.io)",
            "WebFetch(domain:registry.bazel.build)",
            "WebFetch(domain:docs.rs)",
            "ReadFile(**)",
            "Read(~/.cache/**)",
            "Read(~/devel/**)",
            "Read(**)",
            "Write(tools/**)",
            "LS(**)",
            "Glob(**)",
            "Find(**)",
            "Search(**)",
            "Grep(**)",
            "Agent",
            "Bash(cd:~/devel/*)",
            "Bash(cd:*)",
            "Bash(grep:*)",
            "Bash(grep -R:*)",
            "Bash(rg:*)",
            "Bash(ripgrep:*)",
            "Bash(cat:*)",
            "Bash(head:*)",
            "Bash(tail:*)",
            "Bash(less:*)",
            "Bash(awk:*)",
            "Bash(sed -n:*)",
            "Bash(wc:*)",
            "Bash(sort:*)",
            "Bash(uniq:*)",
            "Bash(find:*)",
            "Bash(test:*)",
            "Bash(ls:*)",
            "Bash(ls -la:*)",
            "Bash(tree:*)",
            "Bash(git diff:*)",
            "Bash(git show:*)",
            "Bash(git log:*)",
            "Bash(git status)",
            "Bash(git push)",
            "Bash(git fetch *)",
            "Bash(git ls-tree *)",
            "Bash(gh run list:*)",
            "Bash(gh run view:*)",
            "Bash(gh issue:*)",
            "Bash(gh pr view:*)",
            "Bash(gh pr diff:*)",
            "Bash(bazel run //:buildifier.check)",
            "Bash(bazel run //:buildifier.fix)",
            "Bash(bazel run //tools/format:format)",
            "Bash(bazel build:*)",
            "Bash(bazel query:*)",
            "Bash(bazel cquery:*)",
            "Bash(bazel test:*)",
            "Bash(bazel info:*)",
            "Bash(./tools/lint/lint.sh:*)"
        ],
        "deny": []
    },
    "env": {
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
    }
}